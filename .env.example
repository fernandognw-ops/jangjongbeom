# 전 직원 실시간 데이터 공유 (Supabase)
# Supabase 대시보드 > Project Settings > API 에서 확인

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# 재고 알림 (카카오톡) - 품절 임박 시 1,000만원 이상 핵심 품목 알림
# KAKAO_REST_API_KEY: 카카오 개발자 콘솔 > 앱 설정 > REST API 키
# KAKAO_CHAT_WEBHOOK_URL: 카카오톡 단톡방 웹훅 URL (예: Zapier, Make, n8n 등)
# NEXT_PUBLIC_APP_URL: 대시보드 링크용 (알림 등)
NEXT_PUBLIC_APP_URL=https://jangjongbeom.vercel.app

# KAKAO_API_KEY=
# KAKAO_REST_API_KEY=
# KAKAO_CHAT_WEBHOOK_URL=
